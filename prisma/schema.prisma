generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Setting {
  key         String   @id
  value       String   @db.Text
  type        String // e.g., "boolean", "string", "integer"
  description String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("settings")
}
