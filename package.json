{
    "name": "api",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun --watch run ./src/index.ts",
        "test": "bun test",
        "linter:fix": "eslint --fix",
        "prettier:check": "prettier . --check",
        "prettier:write": "prettier . --write",
        "ts:check": "tsc",
        "prepare": "husky",
        "docker:build": "docker build -t api .",
        "docker:start": "scripts/run-docker.sh",
        "docker:stop": "docker-compose down",
        "docker:dev": "scripts/run-docker.sh dev",
        "docker:dev:stop": "docker-compose --profile dev down",
        "docker:logs": "docker-compose logs -f",
        "monitoring:logs": "docker-compose logs -f prometheus alertmanager"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/bun": "latest",
        "eslint": "^9.39.2",
        "globals": "^17.1.0",
        "husky": "^9.1.7",
        "jiti": "^2.6.1",
        "lint-staged": "^16.2.7",
        "prettier": "3.8.1",
        "typescript-eslint": "^8.54.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.4.0",
        "@hono/swagger-ui": "^0.5.3",
        "@hono/zod-openapi": "^1.2.0",
        "@hono/zod-validator": "^0.7.6",
        "hono": "^4.11.6",
        "hono-rate-limiter": "^0.5.3",
        "pino": "^10.3.0",
        "pino-pretty": "^13.1.3",
        "prom-client": "^15.1.3",
        "zod": "^4.3.6"
    }
}
