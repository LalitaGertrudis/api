{
    "name": "api",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun --watch run ./src/index.ts",
        "test": "bun test",
        "linter:fix": "eslint --fix",
        "prettier:check": "prettier . --check",
        "prettier:write": "prettier . --write",
        "ts:check": "tsc",
        "prepare": "husky",
        "docker:build": "docker build -t api .",
        "docker:start": "scripts/run-docker.sh",
        "docker:stop": "docker-compose down",
        "docker:dev": "scripts/run-docker.sh dev",
        "docker:dev:stop": "docker-compose --profile dev down",
        "docker:destroy": "docker-compose down -v --rmi all --remove-orphans",
        "docker:logs": "docker-compose logs -f",
        "monitoring:logs": "docker-compose logs -f prometheus alertmanager"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bun": "latest",
        "@types/pg": "^8.18.0",
        "eslint": "^10.0.3",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jiti": "^2.6.1",
        "prettier": "3.8.1",
        "typescript-eslint": "^8.57.0"
    },
    "peerDependencies": {
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "@hono/swagger-ui": "^0.6.1",
        "@hono/zod-openapi": "^1.2.2",
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "hono": "^4.12.7",
        "hono-rate-limiter": "^0.5.3",
        "pg": "^8.20.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "prisma": "^7.5.0",
        "prom-client": "^15.1.3",
        "zod": "^4.3.6"
    },
    "prisma": {
        "seed": "bun run prisma/seed.ts"
    }
}
